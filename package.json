{
  "name": "nicsi-erp-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-with-env.mjs .env.local next dev -p 3000",
    "dev:local": "node scripts/run-with-env.mjs .env.local next dev -p 3000",
    "dev:vm": "node scripts/run-with-env.mjs .env.development next dev -H 0.0.0.0 -p 3000",
    "local": "node scripts/build-and-serve-static.mjs",
    "run": "node scripts/serve-home-static.mjs",
    "site:build": "node scripts/build-static-audit.mjs",
    "site:run": "node scripts/serve-home-static.mjs",
    "build": "node scripts/run-with-env.mjs .env.production next build",
    "build:development": "node scripts/run-with-env.mjs .env.development next build",
    "build:staging": "node scripts/run-with-env.mjs .env.staging next build",
    "build:production": "node scripts/run-with-env.mjs .env.production next build",
    "build:audit": "node scripts/build-static-audit.mjs",
    "build:static": "node scripts/build-static-audit.mjs",
    "serve:static": "node scripts/serve-home-static.mjs",
    "audit:static": "node scripts/audit-static-links.mjs",
    "start": "node scripts/run-with-env.mjs .env.production next start -H 0.0.0.0 -p 3000",
    "start:development": "node scripts/run-with-env.mjs .env.development next start -H 0.0.0.0 -p 3000",
    "start:staging": "node scripts/run-with-env.mjs .env.staging next start -H 0.0.0.0 -p 3000",
    "start:production": "node scripts/run-with-env.mjs .env.production next start -H 0.0.0.0 -p 3000",
    "lint": "eslint"
  },
  "dependencies": {
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.16.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "typescript": "^5"
  },
  "homepage": "/nicsi"
}
